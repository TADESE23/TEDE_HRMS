classDiagram
    %% 3.1.3 Object Model for UOG TEDE Campus HRMS
    %% Represents the static structure of the system classes/entities

    class User {
        +int id
        +string email
        +string password_hash
        +enum role
        +enum status
        +timestamp last_login
        +login()
        +logout()
        +changePassword()
    }

    class Employee {
        +int id
        +int user_id
        +string first_name
        +string last_name
        +string employee_id_number
        +string department
        +string role
        +date date_of_joining
        +updateProfile()
        +requestLeave()
    }

    class AcademicProfile {
        +int id
        +int employee_id
        +string academic_rank
        +string specialization
        +int total_publications
        +updateRank()
    }

    class Department {
        +int id
        +string name
        +string head_of_department
        +int college_id
        +getStaffCount()
    }

    class LeaveRequest {
        +int id
        +int employee_id
        +enum leave_type
        +date start_date
        +date end_date
        +string status
        +approve()
        +reject()
    }

    class AttendanceRecord {
        +int id
        +int employee_id
        +date date
        +time check_in_time
        +time check_out_time
        +enum status
        +markAttendance()
    }

    class PayrollRecord {
        +int id
        +int employee_id
        +decimal basic_salary
        +decimal net_pay
        +decimal tax
        +date month_year
        +generateSlip()
    }

    class Candidate {
        +int id
        +string first_name
        +string resume_text
        +decimal ai_match_score
        +string prediction_label
        +evaluate()
    }

    class HRForecast {
        +int id
        +date forecast_date
        +string metric
        +decimal predicted_value
        +decimal confidence_score
        +generate()
    }

    %% Relationships
    User "1" -- "1" Employee : Accounts
    Employee "1" -- "1" AcademicProfile : Has
    Department "1" -- "*" Employee : Employs
    Employee "1" -- "*" LeaveRequest : Requests
    Employee "1" -- "*" AttendanceRecord : Logs
    Employee "1" -- "*" PayrollRecord : Receives
    Employee "1" -- "*" Document : Owns

    class Document {
        +int id
        +string name
        +string path
        +timestamp uploaded_at
    }
